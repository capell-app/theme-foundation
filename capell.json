{
    "manifest-version": 3,
    "name": "capell-app/theme-foundation",
    "slug": "theme-foundation",
    "displayName": "Foundation Theme",
    "kind": "theme",
    "capellApiVersion": "^4.0",
    "version": "1.x-dev",
    "description": "Capell's foundation theme — base Blade layouts, runtime design tokens, the Tailwind asset pipeline, Blade directives, media/SVG handling, and the override contracts that all vertical Capell themes extend.",
    "product": {
        "group": "Capell Foundation",
        "tier": "free",
        "bundle": "foundation"
    },
    "namespace": "Capell\\FoundationTheme",
    "surfaces": ["admin", "frontend"],
    "dependencies": {
        "requires": [
            "capell-app/core",
            "capell-app/frontend",
            "capell-app/layout-builder",
            "capell-app/navigation"
        ],
        "supports": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\FoundationTheme\\Providers\\FoundationThemeServiceProvider"
        ],
        "admin": [],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": false,
        "settings": true,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": "capell:theme-foundation-setup",
        "demo": "capell:theme-foundation-demo",
        "doctor": null
    },
    "actions": {
        "setup": "Capell\\FoundationTheme\\Actions\\SetupFoundationThemePackageAction",
        "demo": "Capell\\FoundationTheme\\Actions\\InstallFoundationThemeDemoAction"
    },
    "settings": ["Capell\\FoundationTheme\\Settings\\FoundationThemeSettings"],
    "permissions": [],
    "capabilities": ["frontend-assets", "cache-blocking"],
    "security": {
        "riskTier": "low",
        "publicSurface": {
            "routeNames": [],
            "auth": "none",
            "csrfExemptRoutes": [],
            "signedRoutes": [],
            "tokenizedRoutes": [],
            "webhookRoutes": [],
            "throttledRoutes": []
        },
        "sensitiveData": {
            "encryptedFields": [],
            "hashedTokenFields": [],
            "redactedOutputClasses": [
                "Capell\\FoundationTheme\\Actions\\MarkPrimaryHeadingRenderedAction"
            ],
            "plaintextJustifications": []
        },
        "publicOutput": {
            "cacheSafe": true,
            "forbidAuthoringSurface": true,
            "forbidSecrets": true,
            "forbidPublicBladeQueries": true
        },
        "externalHttpClients": {
            "requiresTimeouts": false,
            "requiresSecretRedaction": false,
            "clients": []
        },
        "adminSurface": {
            "authorization": "panel-auth",
            "permissions": []
        }
    },
    "performance": {
        "criticalCss": {
            "required": true,
            "parityViewports": ["mobile", "tablet", "desktop"]
        },
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 40,
        "cacheTags": ["theme-foundation"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale"],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "theme-foundation.package-health",
            "label": "Foundation Theme package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\FoundationTheme\\Health\\FoundationThemeHealthCheck",
            "severity": "critical",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "free",
        "requestedCertification": "first-party",
        "supportPolicy": "capell-first-party",
        "privateDocsRequested": false
    },
    "marketplace": {
        "summary": "The base theme every Capell site and child theme builds on: shared Blade layouts, a runtime design-token system (colours, spacing, radius), the Tailwind asset pipeline, an SVG sanitiser, and the section/area contracts that vertical themes override.",
        "screenshots": [
            {
                "path": "docs/assets/marketplace/extension-card.jpg",
                "alt": "Foundation Theme extension preview image",
                "caption": "Foundation Theme extension preview"
            },
            {
                "path": "docs/screenshots/foundation-homepage.png",
                "alt": "Foundation Theme homepage rendered as a Capell public page.",
                "caption": "Foundation homepage public theme surface"
            },
            {
                "path": "docs/screenshots/foundation-directory.png",
                "alt": "Foundation Theme directory listing with card grid and filtering rhythm.",
                "caption": "Foundation directory listing public theme surface"
            },
            {
                "path": "docs/screenshots/foundation-detail.png",
                "alt": "Foundation Theme detail article with hero, content, and related links.",
                "caption": "Foundation detail article public theme surface"
            },
            {
                "path": "docs/screenshots/foundation-contact.png",
                "alt": "Foundation Theme contact page with form fields and supporting content.",
                "caption": "Foundation contact page public theme surface"
            },
            {
                "path": "docs/screenshots/foundation-empty.png",
                "alt": "Foundation Theme empty state with recovery actions.",
                "caption": "Foundation empty state public theme surface"
            },
            {
                "path": "docs/screenshots/foundation-not-found.png",
                "alt": "Foundation Theme not-found page with navigation recovery actions.",
                "caption": "Foundation page not found public theme surface"
            },
            {
                "path": "docs/screenshots/foundation-cta.png",
                "alt": "Foundation Theme call-to-action page section.",
                "caption": "Foundation call to action public theme surface"
            }
        ],
        "categories": ["admin", "foundation", "frontend"]
    },
    "extends": null,
    "themeKey": "default",
    "contributionTraceability": {
        "deferredContributions": []
    }
}
