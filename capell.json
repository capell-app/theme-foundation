{
    "manifest-version": 3,
    "name": "capell-app/theme-foundation",
    "slug": "theme-foundation",
    "displayName": "Foundation Theme",
    "kind": "theme",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Capell's foundation theme — base Blade layouts, runtime design tokens, the Tailwind asset pipeline, Blade directives, media/SVG handling, and the override contracts that all vertical Capell themes extend.",
    "product": {
        "group": "Capell Foundation",
        "tier": "free",
        "bundle": "foundation"
    },
    "namespace": "Capell\\FoundationTheme",
    "surfaces": ["admin", "frontend"],
    "dependencies": {
        "requires": [
            "capell-app/core",
            "capell-app/frontend",
            "capell-app/layout-builder"
        ],
        "supports": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\FoundationTheme\\Providers\\FoundationThemeServiceProvider"
        ],
        "admin": [],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": false,
        "settings": true,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": "capell:theme-foundation-setup",
        "demo": "capell:theme-foundation-demo",
        "doctor": null
    },
    "actions": {
        "setup": "Capell\\FoundationTheme\\Actions\\SetupFoundationThemePackageAction",
        "demo": "Capell\\FoundationTheme\\Actions\\InstallFoundationThemeDemoAction"
    },
    "settings": [],
    "permissions": [],
    "capabilities": ["frontend-assets", "cache-blocking"],
    "security": {
        "riskTier": "low",
        "publicSurface": {
            "routeNames": [],
            "auth": "none",
            "csrfExemptRoutes": [],
            "signedRoutes": [],
            "tokenizedRoutes": [],
            "webhookRoutes": [],
            "throttledRoutes": []
        },
        "sensitiveData": {
            "encryptedFields": [],
            "hashedTokenFields": [],
            "redactedOutputClasses": [
                "Capell\\FoundationTheme\\Actions\\MarkPrimaryHeadingRenderedAction"
            ],
            "plaintextJustifications": []
        },
        "publicOutput": {
            "cacheSafe": true,
            "forbidAuthoringSurface": true,
            "forbidSecrets": true,
            "forbidPublicBladeQueries": true
        },
        "externalHttpClients": {
            "requiresTimeouts": false,
            "requiresSecretRedaction": false,
            "clients": []
        },
        "adminSurface": {
            "authorization": "panel-auth",
            "permissions": []
        }
    },
    "performance": {
        "criticalCss": {
            "required": true,
            "parityViewports": ["mobile", "tablet", "desktop"]
        },
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 40,
        "cacheTags": ["theme-foundation"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale"],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "theme-foundation.package-health",
            "label": "Foundation Theme package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\FoundationTheme\\Health\\FoundationThemeHealthCheck",
            "severity": "critical",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "free",
        "requestedCertification": "first-party",
        "supportPolicy": "capell-first-party",
        "privateDocsRequested": false
    },
    "marketplace": {
        "summary": "The base theme every Capell site and child theme builds on: shared Blade layouts, a runtime design-token system (colours, spacing, radius), the Tailwind asset pipeline, an SVG sanitiser, and the section/area contracts that vertical themes override.",
        "screenshots": [
            {
                "path": "docs/assets/marketplace/extension-card.jpg",
                "alt": "Foundation Theme extension preview image",
                "caption": "Foundation Theme extension preview"
            },
            {
                "path": "docs/screenshots/theme-foundation-settings-screen.png",
                "alt": "Foundation Theme settings screen in light mode.",
                "caption": "Foundation Theme settings screen"
            },
            {
                "path": "docs/screenshots/theme-foundation-settings-screen-dark.png",
                "alt": "Foundation Theme settings screen in dark mode.",
                "caption": "Foundation Theme settings screen, dark mode"
            },
            {
                "path": "docs/screenshots/foundation-homepage-layout.png",
                "alt": "Foundation Theme homepage layout rendered as a Capell public page",
                "caption": "Homepage layout"
            },
            {
                "path": "docs/screenshots/foundation-standard-page-layout.png",
                "alt": "Foundation Theme standard content page with breadcrumbs and related links",
                "caption": "Standard content page"
            },
            {
                "path": "docs/screenshots/foundation-blog-article-layout.png",
                "alt": "Foundation Theme blog article layout with article hero and related posts",
                "caption": "Blog article layout"
            },
            {
                "path": "docs/screenshots/foundation-listing-layout.png",
                "alt": "Foundation Theme listing layout with card grid, filters, and pagination rhythm",
                "caption": "Listing page layout"
            },
            {
                "path": "docs/screenshots/foundation-contact-form-layout.png",
                "alt": "Foundation Theme contact form layout with fields, consent, and confirmation path",
                "caption": "Contact form layout"
            },
            {
                "path": "docs/screenshots/foundation-search-results-layout.png",
                "alt": "Foundation Theme search results layout with query, excerpts, and metadata",
                "caption": "Search results layout"
            },
            {
                "path": "docs/screenshots/foundation-events-layout.png",
                "alt": "Foundation Theme events listing layout with featured event and date cards",
                "caption": "Events listing layout"
            },
            {
                "path": "docs/screenshots/foundation-membership-gate-layout.png",
                "alt": "Foundation Theme access-gated page layout with teaser and sign-in prompt",
                "caption": "Access-gated page layout"
            }
        ],
        "categories": ["admin", "foundation", "frontend"]
    },
    "extends": null,
    "themeKey": "default",
    "contributionTraceability": {
        "deferredContributions": []
    }
}
